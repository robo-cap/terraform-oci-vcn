# provider identity parameters

api_fingerprint = ""

api_private_key_path = ""

region = "us-phoenix-1"

tenancy_id = ""

user_id = ""

# general oci parameters

compartment_id = ""

label_prefix = "dev"

# vcn parameters


create_internet_gateway = false

create_nat_gateway = false

create_service_gateway = false

enable_ipv6 = false

# Optional IPv6 VCN allocation parameters.
# When enable_ipv6 = true, Oracle GUA allocation defaults to true.
# Subnet ipv6cidr_blocks shorthand entries derive from public/BYO IPv6 first,
# then vcn_ipv6private_cidr_blocks.
# When using only private IPv6 blocks, set vcn_is_oracle_gua_allocation_enabled = false.
# vcn_is_oracle_gua_allocation_enabled = false
# vcn_ipv6private_cidr_blocks          = ["fd00:0:0::/56"]
# vcn_byoipv6cidr_details = [
#   {
#     byoipv6range_id = "ocid1.byoipv6range.oc1..exampleuniqueid"
#     ipv6cidr_block  = "2001:db8:1234::/56"
#   }
# ]

vcn_cidrs = ["10.0.0.0/16", "172.16.0.0/16", "192.168.0.0/24"]

vcn_dns_label = "vcn"

vcn_name = "vcn"

lockdown_default_seclist = false

freeform_tags = {
  environment = "dev"
  lob = "finance"
}

defined_tags = {
  "Operations.CostCenter" = "42"
}

# gateways parameters

internet_gateway_display_name = "igw"
nat_gateway_display_name = "ngw"
service_gateway_display_name = "sgw"
attached_drg_id = null
